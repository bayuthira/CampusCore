# Database
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/campus_core

# Server
SERVER_ADDRESS=127.0.0.1:3000

# Authentication
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=86400

# Face++ integration
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_ENDPOINT=
FACEPP_LIVENESS_ENDPOINT=
USE_FACE_LIVENESS_BE=false
USE_FACE_QUEUE=false
FACE_QUEUE_WORKERS=1
FACE_QUEUE_BREAK_MS=1100
FACE_QUEUE_CAPACITY=100

# Face compare provider switch
# Options: faceplusplus, opencv_sface, disabled
FACE_COMPARE_PROVIDER=faceplusplus
FACE_COMPARE_URL=http://127.0.0.1:8088
FACE_COMPARE_AUTH_CODE=
FACE_COMPARE_THRESHOLD=0.363

# Attendance location and schedule
KAMPUS_LATITUDE=0.0
KAMPUS_LONGITUDE=0.0
KAMPUS_RADIUS_METER=100
JAM_MASUK_KERJA=08:00:00
JAM_PULANG_KERJA=16:00:00
TOLERANSI_KETERLAMBATAN_PERHARI=30
