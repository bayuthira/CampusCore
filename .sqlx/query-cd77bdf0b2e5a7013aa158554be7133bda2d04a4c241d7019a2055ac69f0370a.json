{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            mk.id,\n            mk.kode_mk,\n            mk.nama_mk,\n            mk.sks,\n            mk.semester_target,\n            mk.prodi_id,\n            COALESCE(p.nama_prodi, 'Prodi Tidak Ditemukan') as \"nama_prodi!\"\n        FROM mata_kuliah mk\n        INNER JOIN kurikulum_matakuliah km ON mk.id = km.matakuliah_id\n        LEFT JOIN prodi p ON mk.prodi_id = p.id\n        WHERE km.kurikulum_id = $1\n        ORDER BY mk.kode_mk\n        ",
