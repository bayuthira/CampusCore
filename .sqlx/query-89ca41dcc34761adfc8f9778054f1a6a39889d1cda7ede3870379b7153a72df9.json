  "query": "\n        SELECT k.*, COALESCE(p.nama_prodi, 'Prodi Tidak Ditemukan') as \"nama_prodi!\"\n        FROM kurikulum k\n        LEFT JOIN prodi p ON k.prodi_id = p.id\n        ORDER BY k.tahun_mulai DESC, k.nama ASC\n        ",
