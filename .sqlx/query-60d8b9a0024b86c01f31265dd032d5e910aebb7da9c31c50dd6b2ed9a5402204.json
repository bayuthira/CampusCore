{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            h.id,\n            h.tipe_transaksi as \"tipe_transaksi: _\",\n            h.jumlah,\n            h.saldo_sebelum,\n            h.saldo_setelah,\n            h.catatan,\n            h.tanggal_transaksi,\n            h.user_aksi_id,\n            u.full_name as \"nama_user_aksi!\"\n        FROM histori_stok h\n        JOIN users u ON h.user_aksi_id = u.id\n        WHERE h.aset_id = $1\n        ORDER BY h.tanggal_transaksi DESC\n        ",
