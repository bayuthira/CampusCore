  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            m.id, m.nim, m.nama_mahasiswa, m.angkatan, m.email,\n            m.prodi_id, p.nama_prodi,\n            m.user_id, u.username\n        FROM mahasiswa m\n        LEFT JOIN prodi p ON m.prodi_id = p.id\n        LEFT JOIN users u ON m.user_id = u.id\n        WHERE m.id = $1\n        ",
