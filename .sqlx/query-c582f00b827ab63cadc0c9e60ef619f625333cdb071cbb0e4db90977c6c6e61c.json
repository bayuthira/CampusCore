  "query": "\n        SELECT \n            d.id, d.nidn, d.nama_dosen, d.email, d.prodi_id, \n            p.nama_prodi\n        FROM dosen d\n        LEFT JOIN prodi p ON d.prodi_id = p.id\n        WHERE d.id = $1\n        ",
