{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            m.id,\n            m.nim,\n            m.nama_mahasiswa,\n            m.angkatan,\n            m.email,\n            p.nama_prodi\n        FROM mahasiswa m\n        JOIN prodi p ON m.prodi_id = p.id\n        WHERE m.dosen_pa_id = $1\n        ORDER BY m.nim ASC\n        ",
